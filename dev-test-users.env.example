# Local test login accounts (Supabase Auth + Prisma AppUser)
#
# Setup:
#   1. Copy Supabase keys into .env.local (see .env.example)
#   2. npm run db:push          # or db:migrate on a fresh DB
#   3. npm run db:seed
#   4. npm run auth:bootstrap-dev
#
# Sign in at http://localhost:3000/login

DEV_LOGIN_PASSWORD=FineSet#1dev

# Playwright / E2E (optional)
E2E_USER_EMAIL=admin@fineset.local
E2E_USER_PASSWORD=FineSet#1dev

# Local-only auth bypass — skips Supabase (set in .env.local, never in production)
# DEV_AUTH_BYPASS=true
# DEV_AUTH_ROLE=MASTER_ADMIN

# Accounts created by auth:bootstrap-dev
# admin@fineset.local          MASTER_ADMIN
# manager@store-alpha.local    STORE_MANAGER  (Store Alpha)
# staff-a@store-alpha.local    STAFF          (Store Alpha, EMP001)

# Multi-store dropdown testing (links 4 stores to manager email):
#   npm run db:seed:store-selector
#
# Staff calls page mock data (retention / not-answered / follow-up / external queues):
#   npm run db:seed:staff-calls
