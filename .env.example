# Database — if password contains @, encode it as %40 in the URL (e.g. pass@word → pass%40word)
# Local dev: use direct Postgres URL for both vars.
# Production: use Supabase transaction pooler for DATABASE_URL (port 6543, ?pgbouncer=true).
DATABASE_URL="postgresql://user:password@localhost:5432/jewelry_store_saas?schema=public"
# Direct connection for Prisma migrations (same as DATABASE_URL locally; db.*.supabase.co in prod)
DIRECT_URL="postgresql://user:password@localhost:5432/jewelry_store_saas?schema=public"

# App URL (auth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (public keys are safe for browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase service role — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Bootstrap first admin (npm run auth:bootstrap)
MASTER_ADMIN_EMAIL="admin@fineset.local"
MASTER_ADMIN_PASSWORD="change-me-secure-password"
MASTER_ADMIN_NAME="FineSet Admin"

# Dev test users (npm run auth:bootstrap-dev) — see dev-test-users.env.example
# E2E_USER_EMAIL="admin@fineset.local"
# E2E_USER_PASSWORD="FineSet#1dev"

# Local-only auth bypass — skips Supabase login (never enable in production)
# DEV_AUTH_BYPASS="true"
# Optional default role for unknown emails: STAFF | STORE_MANAGER | MASTER_ADMIN
# DEV_AUTH_ROLE="MASTER_ADMIN"

# Upstash Redis (rate limiting — required in production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# PII field encryption (64 hex chars = 32-byte AES-256 key)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Optional — AI summary for store call notes on dashboard (Google AI Studio key)
# GEMINI_API_KEY=""
