# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jewelry_store_saas?schema=public"

# NextAuth (v5 supports AUTH_* and NEXTAUTH_*)
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials — login with ADMIN_EMAIL + your plain password
ADMIN_EMAIL="admin@fineset.local"
# Base64-encoded bcrypt hash (required — raw bcrypt $ breaks in .env files)
# Generate: node -e "const b=require('bcryptjs'); b.hash('your-password',12).then(h=>console.log(Buffer.from(h).toString('base64')))"
ADMIN_PASSWORD_HASH=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# PII field encryption (64 hex chars = 32-byte AES-256 key)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""
