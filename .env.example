# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jewelry_store_saas?schema=public"

# App URL (auth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (public keys are safe for browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase service role — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Bootstrap first admin (npm run auth:bootstrap)
MASTER_ADMIN_EMAIL="admin@fineset.local"
MASTER_ADMIN_PASSWORD="change-me-secure-password"
MASTER_ADMIN_NAME="FineSet Admin"

# Upstash Redis (rate limiting — required in production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# PII field encryption (64 hex chars = 32-byte AES-256 key)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""
