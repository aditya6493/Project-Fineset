generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoreCategory {
  JEWELRY
  HANDBAGS
  WATCHES
  OTHER
}

model Store {
  id             String        @id @default(cuid())
  name           String
  category       StoreCategory @default(JEWELRY)
  customCategory String?
  city           String
  state          String
  pincode             String?
  businessOwnerName   String?
  businessOwnerEmail  String?
  isActive            Boolean       @default(true)
  deletedAt      DateTime?
  purgeAt        DateTime?
  deletedByEmail String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  appUsers   AppUser[]
  staff      Staff[]
  visits     Visit[]
  customers  Customer[]
  fieldSales FieldSale[]
}

model StoreCategoryOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id           String    @id @default(cuid())
  name         String
  employeeId   String    @unique
  phone        String?
  role         StaffRole @default(STAFF)
  isActive     Boolean   @default(true)
  storeId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  appUser           AppUser?
  store             Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  visits            Visit[]
  callLogs          StaffCallLog[]
  fieldSales        FieldSale[]
  assignedFollowUps FollowUp[]
  phoneRevealLogs   PhoneRevealLog[]

  @@index([storeId, isActive])
}

enum StaffRole {
  STAFF
  STORE_MANAGER
  MASTER_ADMIN
}

enum AppRole {
  MASTER_ADMIN
  BUSINESS_OWNER
  STORE_MANAGER
  STAFF
}

model AppUser {
  id          String    @id @default(cuid())
  authId      String    @unique
  email       String    @unique
  name        String
  role        AppRole
  storeId     String?
  staffId     String?   @unique
  isActive    Boolean   @default(false)
  invitedAt   DateTime?
  activatedAt DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: Restrict)
  staff Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([storeId, role, isActive])
  @@index([email])
}

model AuthAuditLog {
  id        String   @id @default(cuid())
  authId    String?
  email     String?
  event     String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
}

model Customer {
  id           String   @id @default(cuid())
  phone        String
  phoneHash    String
  name         String
  nameSearch   String   @default("")
  phoneLast4   String?
  area         String?
  address      String?
  profession   String?
  gender       String?
  ageGroup     String?
  dateOfBirth  DateTime?
  anniversary  DateTime?
  activeScheme String?
  ghsEnrolled  Boolean  @default(false)
  storeId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  visits     Visit[]
  fieldSales FieldSale[]

  @@unique([phoneHash, storeId])
  @@index([storeId, updatedAt(sort: Desc)])
  @@index([storeId, nameSearch])
  @@index([storeId, phoneLast4])
}

model Visit {
  id                String                   @id @default(cuid())
  visitDate         DateTime                 @default(now())
  inTime            DateTime?
  outTime           DateTime?
  durationMins      Int?
  storeId           String
  staffId           String
  customerId        String?
  customerName        String
  customerPhone       String
  customerPhoneHash   String
  customerNameSearch  String   @default("")
  phoneLast4          String?
  customerType        CustomerType
  visitType         VisitType
  area              String?
  address           String?
  profession        String?
  gender            String?
  ageGroup          String?
  dateOfBirth       DateTime?
  anniversary       DateTime?
  purchaseStatus    PurchaseStatus
  productsPurchased String[]
  productsExplored  String[]
  transactionAmount Float?
  intentTier        IntentTier?
  reasonNoPurchase  String?
  competitorMention String?
  purchaseOccasion  String?
  metalKtPref       String?
  budgetStated      BudgetRange?
  schemeEnrolled    Boolean                  @default(false)
  ghsPolicy         Boolean                  @default(false)
  schemesPitched    SchemeProduct[]          @default([])
  enrollmentOutcome SchemeEnrollmentOutcome?
  monthlyCommitment Float?
  reasonNoEnrollment FieldDeclineReason?
  schemeCompetitorMention String?
  followUpNeeded    Boolean                  @default(false)
  followUpDate      DateTime?
  staffNotes        String?
  sourceChannel     SourceChannel
  lastCallAnswered  CallAnswerStatus?
  lastCallAt        DateTime?
  callValueTier     CallValueTier?
  birthMonth        Int?
  anniversaryMonth  Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  staff           Staff            @relation(fields: [staffId], references: [id], onDelete: Restrict)
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  followUp        FollowUp?
  callLogs        StaffCallLog[]
  phoneRevealLogs PhoneRevealLog[]

  @@index([storeId, visitDate(sort: Desc)])
  @@index([staffId, storeId, visitDate(sort: Desc)])
  @@index([staffId, storeId, visitDate(sort: Desc), lastCallAnswered])
  @@index([staffId, storeId, visitDate(sort: Desc), callValueTier, birthMonth, anniversaryMonth])
  @@index([storeId, customerPhoneHash])
  @@index([storeId, customerNameSearch])
  @@index([storeId, phoneLast4])
}

enum CustomerType {
  NEW
  REPEAT
  VIP
}

enum VisitType {
  WALK_IN
  APPOINTMENT
}

enum PurchaseStatus {
  PURCHASED
  NOT_PURCHASED
  PENDING
}

enum IntentTier {
  HOT
  WARM
  COLD
  BROWSING
}

enum BudgetRange {
  UNDER_15K
  K15_50K
  K50_1L
  ABOVE_1L
  NOT_STATED
}

enum SourceChannel {
  ORGANIC_WALK_IN
  REFERRAL
  SOCIAL_MEDIA
  INTERNET
  PHONE
  TANISHQ_REF
  CARATLANE_REF
  USER_CALLS
  OTHER
}

model FollowUp {
  id              String         @id @default(cuid())
  visitId         String?        @unique
  fieldSaleId     String?        @unique
  assignedStaffId String
  followUpDate    DateTime
  reason          String?
  context         String?
  callOutcome     String?
  outcomeDate     DateTime?
  status          FollowUpStatus @default(OPEN)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  visit         Visit?     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  fieldSale     FieldSale? @relation(fields: [fieldSaleId], references: [id], onDelete: Cascade)
  assignedStaff Staff      @relation(fields: [assignedStaffId], references: [id], onDelete: Restrict)

  @@index([assignedStaffId, status, followUpDate])
}

enum FollowUpStatus {
  OPEN
  CLOSED
  CONVERTED
  NO_RESPONSE
}

enum CallAnswerStatus {
  ANSWERED
  NOT_ANSWERED
}

enum CallValueTier {
  HIGH
  MID
  LOW
}

model StaffCallLog {
  id          String           @id @default(cuid())
  visitId     String?
  fieldSaleId String?
  staffId     String
  answered    CallAnswerStatus
  feedback    String?
  createdAt   DateTime         @default(now())

  visit     Visit?     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  fieldSale FieldSale? @relation(fields: [fieldSaleId], references: [id], onDelete: Cascade)
  staff     Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([visitId, staffId, createdAt(sort: Desc)])
  @@index([fieldSaleId, staffId, createdAt(sort: Desc)])
  @@index([staffId, createdAt(sort: Desc)])
}

model PhoneRevealLog {
  id          String   @id @default(cuid())
  visitId     String?
  fieldSaleId String?
  staffId     String
  createdAt   DateTime @default(now())

  visit     Visit?     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  fieldSale FieldSale? @relation(fields: [fieldSaleId], references: [id], onDelete: Cascade)
  staff     Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([visitId, staffId, createdAt(sort: Desc)])
  @@index([fieldSaleId, staffId, createdAt(sort: Desc)])
}

enum FieldActivityType {
  DOOR_TO_DOOR
  HOUSING_SOCIETY
  CORPORATE
  EVENT_EXHIBITION
  MARKET_STALL
  REFERRAL_MEET
  OTHER
}

enum SchemeProduct {
  GHS
  GPP
  NONE
}

enum SchemeEnrollmentOutcome {
  ENROLLED_GHS
  ENROLLED_GPP
  ENROLLED_BOTH
  INTERESTED
  DECLINED
  CALLBACK
}

enum FieldDeclineReason {
  BUDGET
  ALREADY_ENROLLED
  NOT_INTERESTED
  NEEDS_TIME
  TRUST_CONCERNS
  COMPETITOR_SCHEME
}

model FieldSale {
  id                  String                  @id @default(cuid())
  activityDate        DateTime                @default(now())
  startTime           DateTime?
  endTime             DateTime?
  durationMins        Int?
  storeId             String
  staffId             String
  customerId          String?
  customerName        String
  customerPhone       String
  customerPhoneHash   String?
  customerNameSearch  String   @default("")
  phoneLast4          String?
  customerType        CustomerType
  area                String?
  gender              String?
  ageGroup            String?
  profession          String?
  activityType        FieldActivityType
  locationLabel       String?
  schemesPitched      SchemeProduct[]          @default([])
  enrollmentOutcome   SchemeEnrollmentOutcome?
  monthlyCommitment   Float?
  intentTier          IntentTier?
  reasonNoEnrollment  FieldDeclineReason?
  competitorMention   String?
  followUpNeeded      Boolean                 @default(false)
  followUpDate        DateTime?
  staffNotes          String?
  lastCallAnswered    CallAnswerStatus?
  lastCallAt          DateTime?
  callValueTier       CallValueTier?
  birthMonth          Int?
  anniversaryMonth    Int?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  staff    Staff     @relation(fields: [staffId], references: [id], onDelete: Restrict)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  followUp FollowUp?
  callLogs StaffCallLog[]
  phoneRevealLogs PhoneRevealLog[]

  @@index([staffId, activityDate(sort: Desc)])
  @@index([staffId, storeId, activityDate(sort: Desc), lastCallAnswered])
  @@index([staffId, storeId, activityDate(sort: Desc), callValueTier, birthMonth, anniversaryMonth])
  @@index([storeId, activityDate(sort: Desc)])
}
