generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreCategory {
  JEWELRY
  HANDBAGS
  WATCHES
  OTHER
}

model Store {
  id        String        @id @default(cuid())
  name      String
  category  StoreCategory @default(JEWELRY)
  pincode   String
  city      String
  state     String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  staff     Staff[]
  visits    Visit[]
  customers Customer[]
  fieldSales FieldSale[]
}

model Staff {
  id         String    @id @default(cuid())
  name       String
  employeeId String    @unique
  role       StaffRole @default(STAFF)
  isActive   Boolean   @default(true)
  storeId    String
  createdAt  DateTime  @default(now())

  store      Store          @relation(fields: [storeId], references: [id])
  visits     Visit[]
  callLogs   StaffCallLog[]
  fieldSales FieldSale[]
}

enum StaffRole {
  STAFF
  STORE_MANAGER
  MASTER_ADMIN
}

model Customer {
  id           String   @id @default(cuid())
  phone        String
  phoneHash    String
  name         String
  area         String?
  profession   String?
  gender       String?
  ageGroup     String?
  activeScheme String?
  ghsEnrolled  Boolean  @default(false)
  storeId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store      Store       @relation(fields: [storeId], references: [id])
  visits     Visit[]
  fieldSales FieldSale[]

  @@unique([phoneHash, storeId])
}

model Visit {
  id                String         @id @default(cuid())
  visitDate         DateTime       @default(now())
  inTime            DateTime?
  outTime           DateTime?
  durationMins      Int?
  storeId           String
  staffId           String
  customerId        String?
  customerName      String
  customerPhone     String
  customerPhoneHash String?
  customerType      CustomerType
  visitType         VisitType
  area              String?
  gender            String?
  ageGroup          String?
  purchaseStatus    PurchaseStatus
  productsPurchased String[]
  productsExplored  String[]
  transactionAmount Float?
  intentTier        IntentTier?
  reasonNoPurchase  String?
  competitorMention String?
  purchaseOccasion  String?
  metalKtPref       String?
  budgetStated      BudgetRange?
  schemeEnrolled    Boolean        @default(false)
  ghsPolicy         Boolean        @default(false)
  schemesPitched    SchemeProduct[] @default([])
  enrollmentOutcome SchemeEnrollmentOutcome?
  monthlyCommitment Float?
  reasonNoEnrollment FieldDeclineReason?
  schemeCompetitorMention String?
  followUpNeeded    Boolean        @default(false)
  followUpDate      DateTime?
  staffNotes        String?
  sourceChannel     SourceChannel
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  followUp FollowUp?
  callLogs StaffCallLog[]
}

enum CustomerType {
  NEW
  REPEAT
  VIP
}

enum VisitType {
  WALK_IN
  APPOINTMENT
}

enum PurchaseStatus {
  PURCHASED
  NOT_PURCHASED
  PENDING
}

enum IntentTier {
  HOT
  WARM
  COLD
  BROWSING
}

enum BudgetRange {
  UNDER_15K
  K15_50K
  K50_1L
  ABOVE_1L
  NOT_STATED
}

enum SourceChannel {
  ORGANIC_WALK_IN
  REFERRAL
  SOCIAL_MEDIA
  INTERNET
  PHONE
  TANISHQ_REF
  CARATLANE_REF
  OTHER
}

model FollowUp {
  id              String         @id @default(cuid())
  visitId         String         @unique
  assignedStaffId String
  followUpDate    DateTime
  reason          String?
  context         String?
  callOutcome     String?
  outcomeDate     DateTime?
  status          FollowUpStatus @default(OPEN)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  visit Visit @relation(fields: [visitId], references: [id])
}

enum FollowUpStatus {
  OPEN
  CLOSED
  CONVERTED
  NO_RESPONSE
}

enum CallAnswerStatus {
  ANSWERED
  NOT_ANSWERED
}

model StaffCallLog {
  id        String           @id @default(cuid())
  visitId   String
  staffId   String
  answered  CallAnswerStatus
  feedback  String?
  createdAt DateTime         @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([visitId, staffId, createdAt(sort: Desc)])
  @@index([staffId, createdAt(sort: Desc)])
}

enum FieldActivityType {
  DOOR_TO_DOOR
  HOUSING_SOCIETY
  CORPORATE
  EVENT_EXHIBITION
  MARKET_STALL
  REFERRAL_MEET
  OTHER
}

enum SchemeProduct {
  GHS
  GPP
}

enum SchemeEnrollmentOutcome {
  ENROLLED_GHS
  ENROLLED_GPP
  ENROLLED_BOTH
  INTERESTED
  DECLINED
  CALLBACK
}

enum FieldDeclineReason {
  BUDGET
  ALREADY_ENROLLED
  NOT_INTERESTED
  NEEDS_TIME
  TRUST_CONCERNS
  COMPETITOR_SCHEME
}

model FieldSale {
  id                  String                  @id @default(cuid())
  activityDate        DateTime                @default(now())
  startTime           DateTime?
  endTime             DateTime?
  durationMins        Int?
  storeId             String
  staffId             String
  customerId          String?
  customerName        String
  customerPhone       String
  customerPhoneHash   String?
  customerType        CustomerType
  area                String?
  gender              String?
  ageGroup            String?
  profession          String?
  activityType        FieldActivityType
  locationLabel       String?
  schemesPitched      SchemeProduct[]
  enrollmentOutcome   SchemeEnrollmentOutcome
  monthlyCommitment   Float?
  intentTier          IntentTier?
  reasonNoEnrollment  FieldDeclineReason?
  competitorMention   String?
  followUpNeeded      Boolean                 @default(false)
  followUpDate        DateTime?
  staffNotes          String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([staffId, activityDate(sort: Desc)])
  @@index([storeId, activityDate(sort: Desc)])
}
